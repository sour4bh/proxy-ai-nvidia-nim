NVIDIA_NIM_API_KEY=your_nim_key_here
PROXY_HOST=127.0.0.1
PROXY_PORT=3000

# Persisted runtime JSON (model aliases + optional future keys). Default ./config.json — ignored by git; edit over SSH or via probe dashboard aliases UI.
# PROXYAI_CONFIG_FILE=/var/lib/proxyai/config.json

# scripts/claude-smoke.sh: one-shot `claude -p` through your proxy (~/.env.secrets + .env; see ~/.zshrc / ccn).
# scripts/codex-smoke.sh: `codex exec` via OPENAI-compatible base (POST /v1/responses on this proxy).
# scripts/cursor-smoke.sh: headless `cursor agent` (Cursor cloud; CURSOR_API_KEY or cursor login).
# scripts/cli-smoke.sh: runs claude + codex + cursor smokes. PROXYAI_SKIP_MISSING_CLIS=1 skips missing CLIs (default).
